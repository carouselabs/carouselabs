generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
}

enum IdeaMode {
  TRENDING
  EVERGREEN
  PERSONAL
}

enum IdeaCategory {
  LEADERSHIP
  GROWTH
  PRODUCTIVITY
  STORYTELLING
  INDUSTRY
  PERSONAL_BRAND
  CAREER
  OTHER
}

enum PostFormat {
  CAROUSEL
  SINGLE_IMAGE
  TEXT_ONLY
}

enum PostStatus {
  DRAFT
  GENERATING
  READY
  PUBLISHED
  FAILED
}

enum SlideRole {
  COVER
  CONTENT
  CALLOUT
  CTA
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  EXPIRED
}

enum HistoryStatus {
  BREAKDOWN
  CAPTION
  CAPTION_DONE
  IMAGE
  IMAGE_DONE
  CAROUSEL
  CAROUSEL_DONE
}

// ── Models ───────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  email     String    @unique
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile      Profile?
  ideas        Idea[]
  posts        Post[]
  subscription Subscription?
  linkedIn     LinkedInAccount?
  usage        UsageCounter?
  history      IdeaHistory[]

  @@index([clerkId])
}

model Profile {
  id               String   @id @default(cuid())
  userId           String   @unique
  name             String?
  headline         String?
  industry         String?
  targetAudience   String?
  contentPillars   String[]
  writingStyle     String?
  linkedInUrl      String?
  timezone         String   @default("UTC")
  onboardingDone   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Idea {
  id          String       @id @default(cuid())
  userId      String
  title       String
  hook        String
  mode        IdeaMode
  category    IdeaCategory
  isPinned    Boolean      @default(false)
  isDismissed Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  breakdowns Breakdown[]
  posts      Post[]
  history    IdeaHistory[]

  @@index([userId])
  @@index([userId, isPinned])
}

model Breakdown {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  outline   Json
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([userId])
}

model Post {
  id         String     @id @default(cuid())
  userId     String
  ideaId     String?
  title      String
  caption    String?
  format     PostFormat
  status     PostStatus @default(DRAFT)
  imageUrls  String[]
  r2Keys     String[]
  metadata   Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  publishedAt DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea   Idea?   @relation(fields: [ideaId], references: [id], onDelete: SetNull)
  slides Slide[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model Slide {
  id         String    @id @default(cuid())
  postId     String
  role       SlideRole
  order      Int
  headline   String?
  body       String?
  imageUrl   String?
  r2Key      String?
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([postId, order])
}

model IdeaHistory {
  id            String        @id @default(cuid())
  userId        String
  ideaId        String
  status        HistoryStatus @default(BREAKDOWN)
  isPinned      Boolean       @default(false)
  lastVisitedAt DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId])
  @@index([userId])
  @@index([userId, isPinned])
  @@index([userId, lastVisitedAt])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  razorpaySubId        String?
  razorpayCustomerId   String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([razorpaySubId])
}

model LinkedInAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  linkedInId   String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  name         String?
  pictureUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UsageCounter {
  id           String   @id @default(cuid())
  userId       String   @unique
  postsToday   Int      @default(0)
  postsTotal   Int      @default(0)
  lastResetAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
