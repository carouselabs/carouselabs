generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
}

enum IdeaMode {
  AUTO
  SEEDED
}

enum IdeaCategory {
  LATEST_NEWS
  TRENDING
  INDUSTRY
  RANDOM
}

enum PostFormat {
  CAPTION
  IMAGE
  CAROUSEL
}

enum PostStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum SlideRole {
  HOOK
  BODY
  CTA
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  PAUSED
}

model User {
  id          String    @id @default(cuid())
  clerkUserId String    @unique
  email       String    @unique
  plan        Plan      @default(FREE)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  profile       Profile?
  ideas         Idea[]
  posts         Post[]
  subscription  Subscription?
  linkedIn      LinkedInAccount?
  usageCounters UsageCounter[]

  @@index([email])
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  identity          String
  industry          String
  niche             String?
  audience          Json
  goals             String[]
  tone              String[]
  voicePresets      Json[]
  topics            String[]
  doNotUse          String[]
  cadence           Int?
  referenceCreators String[]
  linkedinSnapshot  Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Idea {
  id          String       @id @default(cuid())
  userId      String
  sessionId   String
  mode        IdeaMode
  seedText    String?
  category    IdeaCategory
  hook        String
  postType    String
  cta         String
  isPinned    Boolean      @default(false)
  isDismissed Boolean      @default(false)
  createdAt   DateTime     @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  breakdown Breakdown?
  posts     Post[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isPinned])
}

model Breakdown {
  id          String   @id @default(cuid())
  ideaId      String   @unique
  contentJson Json
  createdAt   DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
}

model Post {
  id              String     @id @default(cuid())
  userId          String
  ideaId          String?
  format          PostFormat
  caption         String?
  status          PostStatus @default(DRAFT)
  publishedAt     DateTime?
  linkedinPostUrn String?
  isFavourite     Boolean    @default(false)
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea   Idea?   @relation(fields: [ideaId], references: [id])
  slides Slide[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

model Slide {
  id         String    @id @default(cuid())
  postId     String
  slideIndex Int
  role       SlideRole
  prompt     String?
  imageUrl   String?
  text       String?
  order      Int
  createdAt  DateTime  @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  razorpaySubscriptionId String             @unique
  plan                   Plan
  status                 SubscriptionStatus
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinkedInAccount {
  id                    String   @id @default(cuid())
  userId                String   @unique
  linkedinUserId        String
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  expiresAt             DateTime
  scope                 String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageCounter {
  userId         String
  date           DateTime @db.Date
  postsGenerated Int      @default(0)
  dailyCap       Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
  @@index([userId, date])
}
